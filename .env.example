SN_INSTANCE=mycompanyInstanceName
SN_USERNAME=service.account
SN_PASSWORD=replace_me
SN_JDBC_DRIVER_CLASS=com.snc.db.jdbc.JDBCDriver
SN_JDBC_JAR_PATH=/app/drivers/ServiceNow-JDBC-2.0.0.jar
# Internal chunk size for large SELECTs (not a row cap — honors your SQL LIMIT).
SN_JDBC_PAGE_SIZE=10000
# JVM heap for JDBC (JPype). Set Docker memory limit above this plus Python headroom.
JAVA_TOOL_OPTIONS=-Xmx2g
API_ONLY=false