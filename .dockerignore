**/__pycache__
**/*.pyc
**/.pytest_cache
**/.mypy_cache

# Web build artifacts and dependencies (rebuilt inside the image)
web/node_modules
web/dist

# Host copy of the bundled UI must never enter the context: it is easy to have a
# stale tree here after `cd web && npm run build`, and `COPY --from=web-builder`
# merges into this folder — leaving orphaned hashed chunks and broken loads.
src/static/dist

# Local-only files
.env
.env.local
*.log
.DS_Store
.git
.gitignore
.idea
.vscode
